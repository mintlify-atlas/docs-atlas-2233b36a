  "keyFeatures": [
    "Model-agnostic persistent memory system stored as local Markdown files",
    "110+ pre-built decision frameworks and protocols across 15 categories",
    "Hybrid RAG search with semantic search, keyword matching, and reranking",
    "50+ slash commands for workflows (start, end, think, research)",
    "CLI tools for workspace initialization and agent management",
    "Multi-IDE support (Antigravity, Cursor, Claude Code, VS Code)",
    "Governed autonomy with 4-level capability tokens and security rails",
    "MCP server with 8 tools and 2 resources for tool integration",
    "Session-based memory that compounds over time",
    "Git-based version control for all memory and protocols"
  ],
  "publicApiSurface": [
    "athena init - Initialize new workspace",
    "athena check - Basic health check",
    "athena doctor - Full system diagnostics",
    "athena save - Quicksave checkpoint",
    "/start - Boot session workflow",
    "/end - Close session workflow",
    "/think - Deep reasoning mode",
    "/ultrathink - Maximum depth reasoning",
    "/research - Multi-source research workflow",
    "/save - Manual checkpoint workflow",
    "smart_search() - Hybrid RAG search",
    "quicksave() - Save session checkpoint",
    "health_check() - System health audit",
    "recall_session() - Retrieve session logs",
    "governance_status() - Check compliance state"
  ]
}
